<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Llama Mail Pairing</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>llamalabels</string>
			</array>
		</dict>
	</array>
	<!-- Bundled fonts (STYLE_GUIDE §2). Copy Bundle Resources flattens the
	     Resources/Fonts group, so iOS names the files directly and macOS
	     points at the Resources directory itself. -->
	<key>UIAppFonts</key>
	<array>
		<string>SpaceGrotesk-Regular.ttf</string>
		<string>SpaceGrotesk-Medium.ttf</string>
		<string>SpaceGrotesk-SemiBold.ttf</string>
		<string>SpaceGrotesk-Bold.ttf</string>
		<string>IBMPlexMono-Regular.ttf</string>
		<string>IBMPlexMono-Medium.ttf</string>
		<string>IBMPlexMono-SemiBold.ttf</string>
		<string>IBMPlexMono-Bold.ttf</string>
	</array>
	<key>ATSApplicationFontsPath</key>
	<string>.</string>
	<key>NSCameraUsageDescription</key>
	<string>llama Mail uses the camera to scan pairing QR codes.</string>
	<key>NSContactsUsageDescription</key>
	<string>llama Mail exports your synced contacts to Apple Contacts when enabled in Preferences.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.urlxl.mail.pull</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
